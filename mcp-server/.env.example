# ── Required ─────────────────────────────────────────────────────────────────

# Your Anthropic API key. Set a monthly spend cap on the key in the Anthropic
# console so a runaway or hostile client can't drain your account.
ANTHROPIC_API_KEY=sk-ant-api03-...

# Port the Bun server listens on. Dockerfile also exposes this.
PORT=3001


# ── Optional (safety / ops) ──────────────────────────────────────────────────

# Kill switch. Set to "1" to short-circuit /ask and /mcp with a degraded
# response — no LLM calls billed. Flip this the moment you notice abuse.
AGENT_DISABLED=0

# Rate limiting. Defaults are 10 requests per minute per client IP.
# RATE_LIMIT_MAX=10
# RATE_LIMIT_WINDOW_MS=60000

# Bot allowlist. Comma-separated UA substrings to allow through the /mcp bot
# filter. Leave unset to use the default deny-only policy (blocks GPTBot,
# CCBot, ClaudeBot, etc.). Only add here if you have a specific reason.
# ALLOWED_BOTS=MyCustomBot,AnotherBot


# ── Optional (analytics) ─────────────────────────────────────────────────────

# Google Analytics 4 — Measurement Protocol credentials for the server-side
# `agent_mcp_connected` event, fired whenever an external MCP client (Claude
# Desktop, Cursor, etc.) connects. Both vars must be set for the beacon to
# fire; it no-ops silently if either is missing. No raw User-Agent data is
# ever sent — only a bucket ("claude-desktop", "cursor", etc.).
# GA4_MEASUREMENT_ID=G-XXXXXXXXXX
# GA4_API_SECRET=your-api-secret-from-GA4-admin
