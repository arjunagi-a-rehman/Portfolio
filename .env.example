# ── Astro (PUBLIC_* is inlined into the client bundle at build time) ─────────

# Convex backend URL for comments/likes/contact form. Run `npx convex dev`
# locally and copy the URL it prints here. Required for the engagement
# features to work; a fork that doesn't use Convex can leave this unset
# and simply not mount the engagement components.
PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud

# URL of your deployed MCP server. Leave as localhost:3001 for local dev;
# set to your production MCP domain before deploying the Astro site.
PUBLIC_MCP_SERVER_URL=http://localhost:3001

# Email address shown on the /agent "Send a note" handoff button. Also the
# `mailto:` target when ContactModal isn't mounted. Forkers: set this to
# your own email so no-match and error states route to you, not Rehman.
PUBLIC_CONTACT_EMAIL=contact@arjunagiarehman.com
