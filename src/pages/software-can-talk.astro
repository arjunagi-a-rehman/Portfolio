  <script>
    // Wire the TRY ASKING items to fill the AgentChat composer in the sidebar.
    // Clicks dispatch a native input event so React's controlled textarea
    // sees the change. Same pattern as a chip click — fill, focus, no submit.
    function wireTryAsking() {
      const items = document.querySelectorAll('.try-asking-item');
      const setter = Object.getOwnPropertyDescriptor(
        HTMLTextAreaElement.prototype,
        'value',
      )?.set;
      items.forEach((btn) => {
        btn.addEventListener('click', () => {
          const prompt = (btn as HTMLButtonElement).dataset.prompt ?? '';
          const ta = document.querySelector(
            '.article-agent-sidebar .ac-textarea',
          ) as HTMLTextAreaElement | null;
          if (!ta || !setter) return;
          setter.call(ta, prompt);
          ta.dispatchEvent(new Event('input', { bubbles: true }));
          ta.focus();
          ta.setSelectionRange(prompt.length, prompt.length);
          ta.scrollIntoView({ behavior: 'smooth', block: 'center' });
        });
      });
    }
    document.addEventListener('astro:page-load', wireTryAsking);
    // Astro:page-load doesn't fire on initial direct nav; cover that:
    if (document.readyState !== 'loading') wireTryAsking();
    else document.addEventListener('DOMContentLoaded', wireTryAsking);
  </script>

