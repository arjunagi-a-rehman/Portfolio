  .bio-card-label {
    font-family: var(--font-mono);
    font-size: 0.67rem;
    color: var(--text-dim);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-bottom: 2px;
  }
  .bio-card-value {
    font-size: 0.88rem;
    color: var(--text);
    font-family: var(--font-head);
    font-weight: 500;
