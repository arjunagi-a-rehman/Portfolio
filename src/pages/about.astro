  .timeline-content {
    padding: 24px 28px;
  }

  .timeline-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 16px;
    margin-bottom: 16px;
    flex-wrap: wrap;
  }

  .timeline-role {
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--text);
    font-family: var(--font-head);
    letter-spacing: 0.02em;
  }
  .timeline-company {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--cyan);
    margin-top: 3px;
    letter-spacing: 0.06em;
  }

  .timeline-meta {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 4px;
    flex-shrink: 0;
  }
  .timeline-period {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--text-dim);
    letter-spacing: 0.05em;
  }
  .timeline-type {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.08em;
    padding: 2px 8px;
