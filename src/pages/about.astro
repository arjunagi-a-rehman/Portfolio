---

<Layout
  title="About — Arjunagi A. Rehman | Backend & AI Systems Engineer"
  description="Backend & AI systems engineer based in Bangalore. 4+ years building production systems — enterprise AI agents (Kalrav.AI), fleet tracking at BIAL, multi-agent assistants, and cloud-native backends."
  currentPath="/about"
  ogType="profile"
  structuredData={aboutSchema}
>

  <!-- ── PAGE HEADER ── -->
  <section class="about-header">
    <div class="container">
      <div class="section-label">About Me</div>
      <h1 class="page-title">
        Backend &amp;<br />
        <span class="gradient-text">AI Systems Architect</span>
      </h1>
      <p class="about-tagline">
        Backend &amp; AI systems engineer with a strong 0→1 product mindset. I build reliable AI agents,
        real-time communication workflows, and distributed backends designed for production, not demos.
        I work across the full lifecycle — architecting systems, integrating with users, iterating quickly,
        and owning outcomes end-to-end.
      </p>

      <div class="about-bio-cards">
        <div class="bio-card">
          <div class="bio-card-icon">◉</div>
          <div>
            <div class="bio-card-label">Location</div>
            <div class="bio-card-value">Bangalore, India</div>
          </div>
        </div>
        <div class="bio-card">
          <div class="bio-card-icon">⬡</div>
          <div>
            <div class="bio-card-label">Focus</div>
            <div class="bio-card-value">AI Agents, IoT, Cloud-Native, Real-time Systems</div>
          </div>
        </div>
        <div class="bio-card">
          <div class="bio-card-icon">◈</div>
          <div>
            <div class="bio-card-label">Contact</div>
            <div class="bio-card-value">
              <a href="mailto:contact@arjunagiarehman.com" class="bio-link">contact@arjunagiarehman.com</a>
            </div>
          </div>
        </div>
        <div class="bio-card">
          <div class="bio-card-icon">{ }</div>
          <div>
            <div class="bio-card-label">GitHub</div>
            <div class="bio-card-value">
              <a href="https://github.com/arjunagi-a-rehman" target="_blank" rel="noopener" class="bio-link">arjunagi-a-rehman</a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── EXPERIENCE ── -->
  <section class="experience-section">
    <div class="container">
      <div class="section-label">Career</div>
      <h2 class="section-title">Work <span class="gradient-text">Experience</span></h2>

      <div class="timeline">
        {experience.map((job, i) => (
          <article class="timeline-item" style={`animation-delay:${i * 0.12}s`}>
            <div class="timeline-dot">
              <div class="timeline-dot-inner"></div>
            </div>
            <div class="timeline-content card">
              <div class="timeline-header">
                <div class="timeline-role-info">
                  <h3 class="timeline-role">{job.role}</h3>
                  <div class="timeline-company">{job.company}</div>
                </div>
                <div class="timeline-meta">
                  <span class="timeline-period">{job.period}</span>
                  <span class="timeline-type">{job.type}</span>
                </div>
              </div>
              <ul class="timeline-highlights">
                {job.highlights.map(h => (
                  <li class="timeline-highlight">
                    <span class="highlight-bullet">›</span>
                    {h}
                  </li>
                ))}
              </ul>
              <div class="timeline-tags">
                {job.tags.map(t => <span class="tag">{t}</span>)}
              </div>
              {(job as any).featuredProject && (
                <a href={(job as any).featuredProject.url} target="_blank" rel="noopener" class="timeline-project-link">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6M15 3h6v6M10 14L21 3"/></svg>
                  View {(job as any).featuredProject.name}
                </a>
              )}
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ── TECH STACK ── -->
  <section class="stack-section">
    <div class="container">
      <div class="section-label">Skills</div>
      <h2 class="section-title">Technical <span class="gradient-text">Stack</span></h2>

      <div class="stack-grid">
        {Object.entries(techStack).map(([category, items]) => (
          <div class="stack-category">
            <div class="stack-category-label">
              <span class="stack-category-line"></span>
              {category}
            </div>
            <div class="stack-items">
              {items.map(item => (
                <div class="stack-item">
                  <span class="stack-dot"></span>
                  {item}
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── EDUCATION ── -->
  <section class="education-section">
    <div class="container edu-grid">
      <div class="edu-card card">
        <div class="edu-icon">◈</div>
        <div class="edu-content">
          <div class="section-label" style="margin-bottom:8px">Education</div>
          <h3 class="edu-degree">B.Tech in Computer Science</h3>
          <div class="edu-school">BMS Institute of Technology & Management</div>
          <div class="edu-meta">
            <span class="edu-cgpa">CGPA: <strong>8.43</strong></span>
            <span class="edu-badge">Bangalore, India</span>
          </div>
        </div>
      </div>

      <div class="achievements-card card">
        <div class="section-label" style="margin-bottom:16px">Achievements</div>
        <div class="achievements-list">
          {achievements.map(a => (
            <div class="achievement-item">
              <span class="achievement-icon">{a.icon}</span>
              <div>
                <div class="achievement-title">{a.title}</div>
                <div class="achievement-desc">{a.desc}</div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ── CONNECT ── -->
  <section class="connect-section">
    <div class="container">
      <div class="connect-inner card">
        <h2 class="connect-title">Let's <span class="gradient-text">Connect</span></h2>
        <p class="connect-desc">Open to backend engineering, AI systems, and cloud architecture opportunities. Let's discuss what we can build together.</p>
        <div class="connect-actions">
          <a href="mailto:contact@arjunagiarehman.com" class="btn btn-primary">Send Email</a>
          <a href="https://www.linkedin.com/in/arjunagi-a-rehman-moulaali/" target="_blank" rel="noopener" class="btn btn-outline">LinkedIn Profile</a>
          <a href="https://github.com/arjunagi-a-rehman" target="_blank" rel="noopener" class="btn btn-outline">GitHub</a>
        </div>
      </div>
    </div>
  </section>

</Layout>

<script>
  // Re-observe on every ClientRouter navigation. DOMContentLoaded fires only
  // on the initial hard load, so without this wrapper the reveal animation
  // wouldn't trigger when the user navigates BACK to /about via the SPA swap.
  document.addEventListener('astro:page-load', () => {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach(e => {
          if (e.isIntersecting) {
            e.target.classList.add('in-view');
            observer.unobserve(e.target);
          }
        });
      },
      { threshold: 0.1 }
    );
    document.querySelectorAll('.timeline-item, .stack-category').forEach(el => observer.observe(el));
  });
</script>

<style>
  /* ── HEADER ── */
  .about-header {
    padding: 80px 0 60px;
    position: relative;
  }
  .about-header::after {
    content: '';
    position: absolute;
    top: 0;
    right: 0;
    width: 40%;
    height: 100%;
