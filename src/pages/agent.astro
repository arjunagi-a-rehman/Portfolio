---
import Layout from '../layouts/Layout.astro';
import AgentChat from '../components/react/AgentChat.tsx';

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Agent', url: '/agent' },
];

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: 'Ask Rehman — AI Agent',
  description:
    'Talk to my AI persona. Ask about projects, essays, agent architecture, or the coders-to-owners thesis. Every answer is grounded in what I\'ve actually written.',
  url: 'https://arjunagiarehman.com/agent',
  author: {
    '@type': 'Person',
    name: 'Arjunagi A. Rehman',
    url: 'https://arjunagiarehman.com',
  },
};
---

<Layout
  title="Ask Rehman — AI Agent · Arjunagi A. Rehman"
  description="Talk to my AI persona. Ask about projects, essays, agent architecture, or the coders-to-owners thesis. Every answer is grounded in what I've actually written, with inline citations."
  currentPath="/agent"
  ogType="website"
  structuredData={structuredData}
  breadcrumbs={breadcrumbs}
>
  <main class="agent-page">
    <div class="container">
      <AgentChat
        client:load
        mcpServerUrl={import.meta.env.PUBLIC_MCP_SERVER_URL ?? 'http://localhost:3001'}
        contactEmail={import.meta.env.PUBLIC_CONTACT_EMAIL ?? 'contact@arjunagiarehman.com'}
      />
    </div>
  </main>
</Layout>

<style>
  .agent-page {
    padding-top: var(--nav-h);
    min-height: 100vh;
  }

  .container {
    max-width: 780px;
    margin: 0 auto;
    padding: 0 24px;
  }
</style>
