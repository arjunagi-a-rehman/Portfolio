---
import Layout from '../layouts/Layout.astro';

// Fetch GitHub repos at build time
let repos: any[] = [];
try {
  const res = await fetch(
    'https://api.github.com/users/arjunagi-a-rehman/repos?sort=updated&per_page=30&type=owner',
    { headers: { 'Accept': 'application/vnd.github.v3+json' } }
  );
  const all = await res.json();
  repos = Array.isArray(all) ? all.filter((r: any) => !r.fork) : [];
} catch (e) {
  repos = [];
}

const featuredRepos = [
  'ucp-agent',
  'ucp-merchant',
  'ucp-demo-store',
  'gormAuditlog',
  'gemini-multimodal-image-search',
  'school-agents',
  'BedRock-agent-runner',
];
// Sort repos to match featuredRepos order
const displayRepos = featuredRepos
  .map(name => repos.find((r: any) => r.name === name))
  .filter(Boolean)
  .slice(0, 6);
// Fill with remaining if needed
if (displayRepos.length < 6) {
  const rest = repos.filter((r: any) => !featuredRepos.includes(r.name)).slice(0, 6 - displayRepos.length);
  displayRepos.push(...rest);
}

const skillGroups = [
  {
    label: 'Languages',
    icon: '{ }',
    color: 'cyan',
    skills: ['Go', 'Java', 'Python', 'Node.js', 'TypeScript', 'SQL'],
  },
  {
    label: 'Frameworks',
    icon: '⬡',
    color: 'blue',
    skills: ['Spring Boot', 'Gin', 'Flask', 'FastAPI', 'Express', 'React', 'GraphQL'],
  },
  {
    label: 'Cloud & Infra',
    icon: '◈',
    color: 'cyan',
    skills: ['AWS Services', 'ECS', 'EKS', 'CDK', 'Lambda', 'IoT Core', 'Rekognition', 'S3', 'Azure', 'Docker', 'Terraform'],
  },
  {
    label: 'Data & Messaging',
    icon: '⋮',
    color: 'blue',
    skills: ['PostgreSQL', 'MongoDB', 'Redis', 'Qdrant', 'Server-Sent Events', 'WebSocket', 'Kafka'],
  },
  {
    label: 'AI & Agents',
    icon: '◉',
    color: 'blue',
    skills: ['LLM Integration', 'AI Agents', 'Google ADK', 'Azure AI Foundry', 'LangGraph', 'AWS Bedrock', 'Qdrant', 'Intent Classification', 'RAG', 'Multi-lingual NLP'],
  },
  {
    label: 'DevOps',
    icon: '◊',
    color: 'cyan',
    skills: ['GitLab CI/CD', 'GitHub Actions', 'Linux', 'Nginx', 'Prometheus', 'VPS', 'Dokploy'],
  },
];

const projects = [
  {
    name: 'Kalrav.AI',
    description: 'No-code platform to create, deploy, and manage AI agents across any public or private website — accessible through a centralized dashboard. Powering 10+ live businesses. Multi-platform: WooCommerce, Shopify, WordPress plugin, and NPM package.',
    tags: ['LLM', 'Google ADK', 'FastAPI', 'WooCommerce', 'Shopify', 'Zoho CRM', 'Multi-lingual', 'Node.js'],
    link: 'https://kalrav.ai/',
    github: null,
    detailPage: '/projects/kalrav',
    type: 'Production',
    badge: '10+ Live Customers',
  },
  {
    name: 'ChotU.AI',
    description: 'Multi-agent personal assistant built with LangGraph & OpenRouter. Supervisor agent routes to specialized sub-agents for task management, Google Calendar integration, daily planning, and personal data storage. Deployed on AWS ECS Fargate with React + Vite frontend on S3/CloudFront.',
    tags: ['LangGraph', 'OpenRouter', 'ECS Fargate', 'AWS CDK', 'React', 'Google Calendar', 'Multi-Agent'],
    link: 'https://www.chotuai.in/',
    github: null,
    detailPage: '/projects/chotuai',
    type: 'AI/ML',
    badge: '5 Specialized Agents',
  },
  {
    name: 'RouteEye',
    description: 'High-frequency fleet management platform processing vehicle telemetry every 5 seconds. Live at Bangalore International Airport (BIAL) for staff shuttle tracking. Built with Go, AWS IoT Core, Redis Pub/Sub, and SSE.',
    tags: ['Go', 'AWS IoT Core', 'Lambda', 'Redis', 'SSE', 'PostgreSQL', 'Microservices'],
    link: 'https://routeeye.io/',
    github: null,
    detailPage: '/projects/routeeye',
    type: 'Production',
    badge: 'Live at BIAL',
  },
  {
    name: 'Wisp',
    description: 'Drink-spiking prevention platform combining portable spectroscopy hardware with a real-time mobile safety app. SOS alerts, live location sharing, and sub-3-second scan results.',
    tags: ['IoT', 'Go', 'AWS', 'Real-time', 'Spectroscopy', 'Mobile'],
    link: 'https://www.get-wisp.com/',
    github: null,
    detailPage: '/projects/wisp',
    type: 'Production',
    badge: 'Hardware + Mobile',
  },
  {
    name: 'ecai',
    description: 'Multimodal RAG platform on Azure. Documents uploaded to Blob Storage → text & images extracted → embedded via text-embedding-3-small → indexed in Azure AI Search → GPT-4.1 powered chat with contextual recall. Retrieval surfaces relevant text chunks + images together.',
    tags: ['Azure AI Foundry', 'GPT-4.1', 'Azure AI Search', 'FastAPI', 'React 18', 'Blob Storage', 'RAG', 'Multimodal'],
    link: null,
    github: null,
    detailPage: '/projects/ecai',
    type: 'AI/ML',
    badge: 'Multimodal RAG',
  },
  {
    name: 'GormAuditLog',
    description: 'Open-source Go library for ORM-level audit logging with GORM. Tracks create/update/delete events with minimal configuration overhead.',
    tags: ['Go', 'GORM', 'Open Source', 'MySQL', 'PostgreSQL'],
    link: null,
    github: 'https://github.com/arjunagi-a-rehman/gormAuditlog',
    type: 'Open Source',
  },
  {
    name: 'School Agents',
    description: 'Multi-agent AI tutoring system built with Google ADK. Specialized agents handle curriculum planning, Q&A, progress tracking, and adaptive learning paths for students.',
    tags: ['Google ADK', 'Python', 'Multi-Agent', 'LLM', 'Education'],
    link: null,
    github: 'https://github.com/arjunagi-a-rehman/school-agents',
    type: 'AI/ML',
    badge: null,
  },
  {
    name: 'BedRock Agent Runner',
    description: 'Local execution framework for AWS Bedrock agents — run and test Bedrock AI agents in a local development environment with multiple interface modes.',
