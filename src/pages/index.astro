const latestPosts = [...blogPosts]
  .sort((a, b) => {
    if (a.featured !== b.featured) return a.featured ? -1 : 1;
    if (a.date !== b.date) return b.date.localeCompare(a.date);
    return 0;
  })
  .slice(0, 3);

const seriesLine = (p: (typeof blogPosts)[number]) =>
  p.part != null
    ? `${p.series} · Part ${p.part}`
    : `${p.series} · ${p.readTime} read`;

// Fetch GitHub repos at build time. Minimal shape — only the fields the
// card template below actually reads. Nullable fields (description, language)
// reflect the real API response for empty repos.
type Repo = {
  name: string;
  fork: boolean;
  html_url: string;
  description: string | null;
  language: string | null;
  stargazers_count: number;
};

let repos: Repo[] = [];
try {
  const res = await fetch(
    'https://api.github.com/users/arjunagi-a-rehman/repos?sort=updated&per_page=30&type=owner',
    { headers: { Accept: 'application/vnd.github.v3+json' } },
  );
  // Rate-limited / 404 / auth-failed responses are JSON objects, not arrays.
  // Silently serving an empty repos section on a broken API would mask the
  // degradation on every build. Log it so someone notices.
  if (!res.ok) {
    console.warn(
      `[index.astro] GitHub API fetch failed: ${res.status} ${res.statusText}`,
    );
  }
  const all: unknown = await res.json();
  // Trust boundary: validate each item has the shape we depend on before
  // promoting to Repo. GitHub's schema is stable, but this catches upstream
  // changes and rate-limited responses (which return an object, not an array).
  const isRepo = (r: unknown): r is Repo =>
    typeof r === 'object' &&
    r !== null &&
    'name' in r &&
    'fork' in r &&
    'html_url' in r &&
    'stargazers_count' in r;
  repos = Array.isArray(all) ? all.filter(isRepo).filter((r) => !r.fork) : [];
} catch (err) {
  console.warn('[index.astro] GitHub API fetch threw:', err);
  repos = [];
}

const featuredRepos = [
  'ucp-agent',
  'ucp-merchant',
  'ucp-demo-store',
  'gormAuditlog',
  'gemini-multimodal-image-search',
  'school-agents',
  'BedRock-agent-runner',
];
// Sort repos to match featuredRepos order
const displayRepos: Repo[] = featuredRepos
  .map((name) => repos.find((r) => r.name === name))
  .filter((r): r is Repo => r !== undefined)
  .slice(0, 6);
// Fill with remaining if needed
if (displayRepos.length < 6) {
  const rest = repos
    .filter((r) => !featuredRepos.includes(r.name))
    .slice(0, 6 - displayRepos.length);
  displayRepos.push(...rest);
}

