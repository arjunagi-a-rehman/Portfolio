                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6M15 3h6v6M10 14L21 3"/></svg>
                  </a>
                )}
              </div>
            </div>
            <h3 class="project-name">{project.name}</h3>
            <p class="project-desc">{project.description}</p>
            <div class="project-tags">
              {project.tags.map(t => <span class="tag">{t}</span>)}
            </div>
            {detailPage && (
              <div class="project-detail-cta">
                <span>View case study</span>
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              </div>
            )}
          </article>
          );
        })}
      </div>

      {restProjects.length > 0 && (
        <>
        <div class="rest-label"><span>More work</span></div>
        <div class="projects-grid rest-grid">
          {restProjects.map((project, i) => {
            const detailPage = (project as any).detailPage;
            return (
            <article class={`project-card compact card${detailPage ? ' has-detail' : ''}`} style={`animation-delay:${i * 0.08}s`} data-detail={detailPage || ''}>
              <div class="project-card-top">
                <div class="project-type-badge" data-type={project.type}>
                  <span class="type-dot"></span>
