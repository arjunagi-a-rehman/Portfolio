          </a>
          <a href="mailto:contact@arjunagiarehman.com" class="btn btn-outline">
            Get In Touch
          </a>
        </div>

        <div class="hero-stats" style="animation-delay:0.9s">
          <div class="stat">
            <span class="stat-num">10+</span>
            <span class="stat-label">Live systems</span>
          </div>
          <div class="stat-divider"></div>
          <div class="stat">
            <span class="stat-num">5</span>
            <span class="stat-label">AI deployments</span>
          </div>
          <div class="stat-divider"></div>
          <div class="stat">
            <span class="stat-num">4+</span>
            <span class="stat-label">Years exp.</span>
          </div>
          <div class="stat-divider"></div>
          <div class="stat">
            <span class="stat-num">24/7</span>
            <span class="stat-label">Systems at BIAL</span>
          </div>
        </div>
      </div>

      <div class="hero-visual" aria-hidden="true">
        <div class="hero-hex-ring">
