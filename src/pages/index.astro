    link: null,
    github: 'https://github.com/arjunagi-a-rehman/gemini-multimodal-image-search',
    type: 'AI/ML',
  },
];

const typeColors: Record<string, string> = {
  'Production': 'cyan',
  'Open Source': 'blue',
  'Tool': 'silver',
  'AI/ML': 'purple',
};

const featuredProjects = projects.slice(0, 3);
const restProjects = projects.slice(3);

// JSON-LD: Person schema
const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Arjunagi A. Rehman',
  url: 'https://arjunagiarehman.com',
  image: 'https://arjunagiarehman.com/logo.svg',
  jobTitle: 'Backend & AI Systems Architect',
  description: 'Backend & AI systems engineer with a strong 0→1 product mindset. Building reliable AI agents, real-time workflows, and distributed backends designed for production.',
  address: { '@type': 'PostalAddress', addressLocality: 'Bangalore', addressCountry: 'IN' },
  sameAs: [
    'https://github.com/arjunagi-a-rehman',
    'https://www.linkedin.com/in/arjunagi-a-rehman-moulaali/',
  ],
  knowsAbout: ['Go', 'Python', 'AWS', 'LangGraph', 'Google ADK', 'FastAPI', 'IoT', 'AI Agents', 'Real-time Systems'],
};

// JSON-LD: WebSite schema
const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Arjunagi A. Rehman — Portfolio',
  url: 'https://arjunagiarehman.com',
  author: { '@type': 'Person', name: 'Arjunagi A. Rehman' },
  description: 'Portfolio of Arjunagi A. Rehman — Backend & AI systems engineer building production AI agents, real-time systems, and cloud-native backends.',
};
---

<Layout
  title="Arjunagi A. Rehman — Backend & AI Systems Engineer"
  description="Backend & AI systems engineer with a strong 0→1 product mindset. I build reliable AI agents, real-time workflows, and distributed backends for production — based in Bangalore."
  currentPath="/"
  ogType="website"
  structuredData={[personSchema, websiteSchema]}
>

  <!-- ── HERO ── -->
  <section class="hero">
    <div class="container hero-inner">
      <div class="hero-content">
        <div class="hero-greeting" style="animation-delay:0.1s">
          <span class="hero-greeting-line" aria-hidden="true"></span>
          <span class="hero-greeting-text">Hello, I'm</span>
        </div>

        <h1 class="hero-name">
          Arjunagi<br />
          <span class="hero-name-accent">A. Rehman</span>
        </h1>

        <div class="hero-role">
          <span class="sr-only">Backend and AI systems engineer — also cloud solutions engineer, real-time systems builder, and AI agent systems engineer.</span>
          <span class="role-bracket" aria-hidden="true">[</span>
          <span class="role-text" id="role-text" aria-hidden="true">Backend &amp; AI Systems Architect</span>
          <span class="role-cursor" aria-hidden="true">|</span>
          <span class="role-bracket" aria-hidden="true">]</span>
        </div>

        <p class="hero-desc" style="animation-delay:0.6s">
          Backend &amp; AI systems engineer with a strong <span class="highlight">0→1 product mindset</span>.
          I build reliable AI agents, real-time workflows, and distributed backends
          <span class="highlight">designed for production</span>, not demos —
          owning outcomes end-to-end.
        </p>

