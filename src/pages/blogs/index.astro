---
import SubscribeCardIsland from '../../components/react/SubscribeCard';
import { blogPosts } from '../../data/posts';
import Layout from '../../layouts/Layout.astro';

const linkedInPosts = [
  {
    title: 'Building Real-time IoT Systems at Scale',
    excerpt:
      'Lessons learned architecting RouteEye — handling thousands of concurrent device connections with AWS IoT Core and Redis.',
    url: 'https://www.linkedin.com/in/arjunagi-a-rehman-moulaali/',
    tags: ['IoT', 'AWS', 'Architecture'],
  },
  {
    title: 'Why Go is Perfect for IoT Backend Systems',
    excerpt:
      "Go's concurrency model and performance characteristics make it the ideal choice for real-time IoT data processing pipelines.",
    url: 'https://www.linkedin.com/feed/update/urn:li:activity:7434176238950416384/',
    tags: ['Go', 'IoT', 'Backend'],
  },
];

const blogSchema = {
  '@context': 'https://schema.org',
  '@type': 'Blog',
  name: 'Arjunagi A. Rehman — Technical Blog',
  url: 'https://arjunagiarehman.com/blogs',
  description:
    'Technical writing on backend engineering, AI agents, IoT systems, and cloud-native architecture.',
  author: {
    '@type': 'Person',
    name: 'Arjunagi A. Rehman',
    url: 'https://arjunagiarehman.com',
  },
  blogPost: blogPosts.map((post) => ({
    '@type': 'BlogPosting',
    headline: post.title,
    description: post.excerpt,
    url: `https://arjunagiarehman.com${post.slug}`,
    author: { '@type': 'Person', name: 'Arjunagi A. Rehman' },
    datePublished: '2025-01-01',
    keywords: post.tags.join(', '),
  })),
};
---

<Layout
  title="Blogs — Arjunagi A. Rehman | Backend & AI Engineering"
  description="Technical writing on building production AI agents, real-time IoT systems, cloud-native backends, and distributed systems. Deep dives on Go, AWS, LangGraph, and more."
  currentPath="/blogs"
  ogType="website"
  structuredData={blogSchema}
>

  <!-- ── PAGE HEADER ── -->
  <section class="blog-header">
    <div class="container">
      <div class="section-label">Writing</div>
      <h1 class="page-title">
        Technical <span class="gradient-text">Articles</span>
      </h1>
      <p class="blog-tagline">
        Deep dives into backend engineering, IoT systems, AI agents, and cloud architecture.
        Practical guides from real production experience.
      </p>
    </div>
  </section>

  <!-- ── FEATURED POST ── -->
  {blogPosts.filter(p => p.featured).map(post => (
    <section class="featured-post-section">
      <div class="container">
        <div class="section-label">Featured</div>
        <a href={post.slug} class="featured-post card" id={post.id}>
          <div class="featured-post-badge">
            <span class="series-badge">{post.series}</span>
            {post.part && <span class="part-badge">Part {post.part}</span>}
          </div>
          <div class="featured-post-content">
            <h2 class="featured-post-title">{post.title}</h2>
            <p class="featured-post-excerpt">{post.excerpt}</p>
            <div class="featured-post-footer">
              <div class="post-tags">
                {post.tags.map(t => <span class="tag">{t}</span>)}
              </div>
              <div class="post-meta">
                <span class="post-read-time">
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                  {post.readTime} read
                </span>
                <span class="post-cta">Read Article →</span>
              </div>
            </div>
          </div>
          <div class="featured-post-visual" aria-hidden="true">
            <div class="post-hex-grid">
              {Array.from({ length: 9 }).map(() => (
                <div class="post-hex"></div>
              ))}
            </div>
          </div>
        </a>
      </div>
    </section>
  ))}

  <!-- ── DEEP DIVES ── -->
  {blogPosts.filter(p => p.series === 'Deep Dive').length > 0 && (
    <section class="posts-section deep-dives-section">
      <div class="container">
        <div class="section-label">Essays</div>
        <h2 class="section-title">Deep <span class="gradient-text">Dives</span></h2>
        <p class="section-sub">Long-form essays on engineering craft, AI, and the shape of the industry.</p>

        <div class="posts-list">
          {blogPosts.filter(p => p.series === 'Deep Dive').map((post, i) => (
            <a href={post.slug} class="post-row card" id={post.id} style={`animation-delay:${i * 0.1}s`}>
              <div class="post-row-num">
                <span class="part-num essay-glyph">§</span>
              </div>
              <div class="post-row-content">
                <div class="post-row-meta">
                  <span class="post-series-label">{post.series}</span>
                  <span class="post-dot">·</span>
                  <span class="post-read-time">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                    {post.readTime}
                  </span>
                </div>
                <h3 class="post-row-title">{post.title}</h3>
                <p class="post-row-excerpt">{post.excerpt}</p>
                <div class="post-row-tags">
                  {post.tags.map(t => <span class="tag">{t}</span>)}
                </div>
              </div>
              <div class="post-row-arrow">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- ── ALL POSTS ── -->
  <section class="posts-section">
    <div class="container">
      <div class="section-label">Series</div>
      <h2 class="section-title">AI Agent System <span class="gradient-text">Series</span></h2>
      <p class="section-sub">A practical guide to building, extending, and deploying AI agents in production.</p>

      <div class="series-container">
        <div class="series-connector" aria-hidden="true"></div>
        <div class="posts-list">
          {blogPosts.filter(p => p.series === 'AI Agent System Series').map((post, i) => (
            <a href={post.slug} class="post-row card" id={post.id} style={`animation-delay:${i * 0.1}s`}>
              <div class="post-row-num">
                <span class="part-num">{String(post.part).padStart(2, '0')}</span>
              </div>
              <div class="post-row-content">
                <div class="post-row-meta">
                  <span class="post-series-label">{post.series}</span>
                  <span class="post-dot">·</span>
                  <span class="post-read-time">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                    {post.readTime}
                  </span>
                </div>
                <h3 class="post-row-title">{post.title}</h3>
                <p class="post-row-excerpt">{post.excerpt}</p>
                <div class="post-row-tags">
                  {post.tags.map(t => <span class="tag">{t}</span>)}
                </div>
              </div>
              <div class="post-row-arrow">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              </div>
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ── LINKEDIN POSTS ── -->
  <section class="linkedin-section">
    <div class="container">
      <div class="section-label">LinkedIn</div>
      <h2 class="section-title">Professional <span class="gradient-text">Posts</span></h2>
      <p class="section-sub">Shorter-form technical insights shared on LinkedIn.</p>

      <div class="linkedin-grid">
        {linkedInPosts.map(post => (
          <a href={post.url} target="_blank" rel="noopener" class="linkedin-card card">
            <div class="linkedin-icon">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="var(--blue)"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
            </div>
            <h3 class="linkedin-title">{post.title}</h3>
            <p class="linkedin-excerpt">{post.excerpt}</p>
            <div class="linkedin-footer">
              <div class="post-tags">
                {post.tags.map(t => <span class="tag tag-blue">{t}</span>)}
              </div>
              <span class="external-link">
                View on LinkedIn
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6M15 3h6v6M10 14L21 3"/></svg>
              </span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ── NEWSLETTER SUBSCRIBE ── -->
  <section class="subscribe-section">
    <div class="container subscribe-container">
      <SubscribeCardIsland source="blogs-index" client:visible />
      <p class="subscribe-social">
        Or follow on
        <a href="https://github.com/arjunagi-a-rehman" target="_blank" rel="noopener">GitHub</a> ·
        <a href="https://www.linkedin.com/in/arjunagi-a-rehman-moulaali/" target="_blank" rel="noopener">LinkedIn</a>
      </p>
    </div>
  </section>

</Layout>

<script>
  // Re-run on every ClientRouter navigation: a fresh set of .post-row /
  // .linkedin-card nodes appear each time this page is swapped in, and each
  // needs its own observer subscription.
  document.addEventListener('astro:page-load', () => {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach(e => {
          if (e.isIntersecting) {
            e.target.classList.add('in-view');
            observer.unobserve(e.target);
          }
        });
      },
      { threshold: 0.08 }
    );
    document.querySelectorAll('.post-row, .linkedin-card').forEach(el => observer.observe(el));
  });
</script>

<style>
  /* ── HEADER ── */
  .blog-header {
    padding: 80px 0 48px;
  }
  .page-title {
    font-size: clamp(2.4rem, 5vw, 4rem);
    font-weight: 700;
    line-height: 1.1;
    margin-bottom: 20px;
    color: var(--text);
  }
  .blog-tagline {
    font-size: 1rem;
    color: var(--text-dim);
    max-width: 560px;
    line-height: 1.75;
  }

  /* ── FEATURED POST ── */
  .featured-post-section { padding: 0 0 60px; }

  .featured-post {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 32px;
    align-items: center;
    padding: 40px;
    position: relative;
    overflow: hidden;
    cursor: pointer;
  }
  .featured-post::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(0,229,255,0.03) 0%, rgba(21,101,255,0.03) 100%);
    opacity: 0;
    transition: opacity 0.3s;
  }
  .featured-post:hover::after { opacity: 1; }

  .featured-post-badge {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 16px;
  }
  .series-badge {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--cyan);
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }
  .part-badge {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    padding: 2px 8px;
    border: 1px solid var(--border-h);
    border-radius: 99px;
    color: var(--text-dim);
  }

  .featured-post-title {
    font-family: var(--font-head);
    font-size: clamp(1.3rem, 2vw, 1.9rem);
    font-weight: 700;
    color: var(--text);
    line-height: 1.3;
    margin-bottom: 12px;
    transition: color 0.2s;
  }
  .featured-post:hover .featured-post-title { color: var(--cyan); }

  .featured-post-excerpt {
    font-size: 0.93rem;
    color: var(--text-dim);
    line-height: 1.7;
    margin-bottom: 24px;
    max-width: 560px;
  }

  .featured-post-footer {
    display: flex;
    align-items: center;
    gap: 16px;
    flex-wrap: wrap;
  }
  .post-tags { display: flex; flex-wrap: wrap; gap: 6px; }
  .post-meta {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-left: auto;
    flex-shrink: 0;
  }
  .post-read-time {
    display: flex;
    align-items: center;
    gap: 5px;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--text-dim);
  }
  .post-cta {
    font-family: var(--font-mono);
    font-size: 0.82rem;
    color: var(--cyan);
    transition: letter-spacing 0.2s;
  }
  .featured-post:hover .post-cta { letter-spacing: 0.06em; }

  .featured-post-visual {
    flex-shrink: 0;
    padding: 8px;
  }
  .post-hex-grid {
    display: grid;
    grid-template-columns: repeat(3, 40px);
    gap: 8px;
  }
  .post-hex {
    width: 40px;
    height: 40px;
    clip-path: polygon(50% 0%, 100% 25%, 100% 75%, 50% 100%, 0% 75%, 0% 25%);
    background: rgba(0,229,255,0.05);
    border: 1px solid rgba(0,229,255,0.08);
    transition: background 0.3s;
  }
  .featured-post:hover .post-hex:nth-child(odd) {
    background: rgba(0,229,255,0.08);
  }
  .featured-post:hover .post-hex:nth-child(even) {
    background: rgba(21,101,255,0.08);
  }

  /* ── POSTS LIST ── */
  .posts-section { padding: 80px 0; }
  .deep-dives-section { padding-bottom: 20px; }
  .essay-glyph {
    font-family: var(--font-head);
    font-size: 2rem;
    line-height: 1;
  }
  .section-sub {
    color: var(--text-dim);
    font-size: 0.95rem;
    max-width: 460px;
    line-height: 1.7;
    margin-bottom: 40px;
  }

  .series-container { position: relative; }
  .series-connector {
    position: absolute;
    left: 32px;
    top: 0;
    bottom: 0;
    width: 1px;
    background: linear-gradient(to bottom, var(--border-h), var(--border), transparent);
  }

  .posts-list {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .post-row {
    display: flex;
    align-items: flex-start;
    gap: 24px;
    padding: 28px 32px;
    cursor: pointer;
    opacity: 0;
    transform: translateX(-16px);
    transition: opacity 0.5s ease, transform 0.5s ease, border-color 0.3s, background 0.3s, box-shadow 0.3s;
  }
  .post-row.in-view { opacity: 1; transform: translateX(0); }

  .post-row-num {
    flex-shrink: 0;
    width: 40px;
    display: flex;
    justify-content: center;
    padding-top: 4px;
  }
  .part-num {
    font-family: var(--font-mono);
    font-size: 1.6rem;
    font-weight: 700;
    color: rgba(0,229,255,0.15);
    line-height: 1;
    transition: color 0.2s;
  }
  .post-row:hover .part-num { color: rgba(0,229,255,0.4); }

  .post-row-content { flex: 1; }
  .post-row-meta {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 8px;
  }
  .post-series-label {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    color: var(--cyan);
    letter-spacing: 0.1em;
  }
  .post-dot { color: var(--text-dim); font-size: 0.8rem; }

  .post-row-title {
    font-family: var(--font-head);
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--text);
    line-height: 1.35;
    margin-bottom: 8px;
    transition: color 0.2s;
  }
  .post-row:hover .post-row-title { color: var(--cyan); }

  .post-row-excerpt {
    font-size: 0.87rem;
    color: var(--text-dim);
    line-height: 1.6;
    margin-bottom: 12px;
  }

  .post-row-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .post-row-arrow {
    flex-shrink: 0;
    color: var(--text-dim);
    padding-top: 6px;
    transition: color 0.2s, transform 0.2s;
  }
  .post-row:hover .post-row-arrow {
    color: var(--cyan);
    transform: translateX(4px);
  }

  /* ── LINKEDIN ── */
  .linkedin-section { padding: 80px 0; }

  .linkedin-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
    gap: 20px;
    margin-top: 40px;
  }

  .linkedin-card {
    display: block;
    cursor: pointer;
    opacity: 0;
    transform: translateY(16px);
    transition: opacity 0.5s ease, transform 0.5s ease, border-color 0.3s, background 0.3s, box-shadow 0.3s;
  }
  .linkedin-card.in-view { opacity: 1; transform: translateY(0); }

  .linkedin-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border: 1px solid var(--border);
    border-radius: 6px;
    margin-bottom: 14px;
    background: rgba(21,101,255,0.06);
  }

  .linkedin-title {
    font-family: var(--font-head);
    font-size: 1rem;
    font-weight: 700;
    color: var(--text);
    line-height: 1.3;
    margin-bottom: 8px;
    transition: color 0.2s;
  }
  .linkedin-card:hover .linkedin-title { color: var(--cyan); }

  .linkedin-excerpt {
    font-size: 0.87rem;
    color: var(--text-dim);
    line-height: 1.6;
    margin-bottom: 16px;
  }

  .linkedin-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    flex-wrap: wrap;
  }

  .external-link {
    display: flex;
    align-items: center;
    gap: 5px;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--text-dim);
    flex-shrink: 0;
    transition: color 0.2s;
  }
  .linkedin-card:hover .external-link { color: var(--blue); }

  /* ── SUBSCRIBE ── */
  .subscribe-section { padding: 60px 0 100px; }
  .subscribe-container {
    max-width: 620px;
  }
  .subscribe-social {
    margin-top: 18px;
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--text-dim);
    letter-spacing: 0.04em;
  }
  .subscribe-social a {
    color: var(--cyan);
    text-decoration: none;
  }
  .subscribe-social a:hover {
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  /* ── RESPONSIVE ── */
  @media (max-width: 768px) {
    .featured-post {
      grid-template-columns: 1fr;
      padding: 24px;
    }
    .featured-post-visual { display: none; }
    .post-row { padding: 20px; gap: 16px; }
    .series-connector { display: none; }
  }
</style>
