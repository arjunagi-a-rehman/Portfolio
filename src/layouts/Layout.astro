---
import { ClientRouter } from 'astro:transitions';
import CircuitCanvas from '../components/CircuitCanvas.astro';
import Footer from '../components/Footer.astro';
import Nav from '../components/Nav.astro';
import ContactModal from '../components/react/ContactModal.tsx';
import '../styles/global.css';

export interface Props {
  title: string;
  description?: string;
  currentPath?: string;
  ogImage?: string;
  ogType?: 'website' | 'article' | 'profile';
  structuredData?: Record<string, unknown> | Record<string, unknown>[];
  breadcrumbs?: { name: string; url: string }[];
}

const SITE = 'https://arjunagiarehman.com';

const {
  title,
  description = 'Arjunagi A. Rehman — Backend & AI systems architect building production AI agents, real-time pipelines, and cloud-native systems.',
  currentPath = '/',
  ogImage = '/og-default.png',
  ogType = 'website',
  structuredData,
  breadcrumbs,
} = Astro.props;

const canonicalURL = new URL(currentPath, SITE).toString();
const ogImageURL = ogImage.startsWith('http')
  ? ogImage
  : new URL(ogImage, SITE).toString();

// Breadcrumb JSON-LD
const breadcrumbSchema =
  breadcrumbs && breadcrumbs.length > 0
    ? {
        '@context': 'https://schema.org',
        '@type': 'BreadcrumbList',
        itemListElement: breadcrumbs.map((crumb, i) => ({
          '@type': 'ListItem',
          position: i + 1,
          name: crumb.name,
          item: new URL(crumb.url, SITE).toString(),
        })),
      }
    : null;

// Combine all structured data
const allSchemas = [
  ...(structuredData
    ? Array.isArray(structuredData)
      ? structuredData
      : [structuredData]
    : []),
  ...(breadcrumbSchema ? [breadcrumbSchema] : []),
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Primary Meta -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Arjunagi A. Rehman" />
    <meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1" />
    <meta name="theme-color" content="#00e5ff" />
    <link rel="canonical" href={canonicalURL} />
    <link rel="alternate" type="text/plain" title="LLM-friendly content" href="https://arjunagiarehman.com/llms.txt" />

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={title} />
    <meta property="og:site_name" content="Arjunagi A. Rehman" />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter / X Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />
    <meta name="twitter:image:alt" content={title} />
    <meta name="twitter:creator" content="@arjunagi_rehman" />
    <meta name="twitter:site" content="@arjunagi_rehman" />

    <!-- Icons -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Chakra+Petch:ital,wght@0,300;0,400;0,600;0,700;1,400&family=Outfit:wght@300;400;500;600&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />

    <!-- Google Analytics -->
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-KPKX4ZXF47"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-KPKX4ZXF47');
    </script>

    <!-- JSON-LD Structured Data -->
    {allSchemas.length > 0 && allSchemas.map(schema => (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    ))}

    <!-- SPA-style navigation. Intercepts internal link clicks, swaps <main>
         content via fetch(), preserves elements marked transition:persist.
         Eliminates the white flash and keeps the background canvas + modal
         state intact across navigations. -->
    <ClientRouter />
  </head>
  <body>
    <!-- CircuitCanvas and Footer carry their own transition:persist internally
         on their root element. For the React island below, the persist directive
         has to be on the component tag because Astro forwards it through the
         <astro-island> wrapper. -->
    <CircuitCanvas />
    <div class="vignette-top" aria-hidden="true"></div>
    <Nav currentPath={currentPath} />
    <main class="main-content" id="main-content">
      <slot />
    </main>
    <Footer />
    <div class="scan-line" aria-hidden="true"></div>
    <ContactModal client:load transition:persist />
  </body>
</html>

<style is:global>
  .vignette-top {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    height: 200px;
    background: linear-gradient(to bottom, rgba(4,9,18,0.6), transparent);
    z-index: 1;
    pointer-events: none;
  }

  .main-content {
    position: relative;
    z-index: 2;
    padding-top: var(--nav-h);
  }

  .scan-line {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: linear-gradient(90deg, transparent 0%, rgba(0,229,255,0.06) 50%, transparent 100%);
    animation: scan-line 8s linear infinite;
    z-index: 99;
    pointer-events: none;
  }
</style>
