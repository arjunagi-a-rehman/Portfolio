---
---
<canvas id="circuit-bg" aria-hidden="true"></canvas>

<script>
(function () {
  const canvas = document.getElementById('circuit-bg') as HTMLCanvasElement;
  if (!canvas) return;
  const ctx = canvas.getContext('2d')!;

  const GRID = 90;
  let W: number, H: number;
  let nodes: Array<{ x: number; y: number; hex: boolean; active: boolean }> = [];
  let segments: Array<{ from: number; to: number }> = [];
  let pulses: Array<{ seg: number; t: number; speed: number; colorStr: string }> = [];

  function build() {
    W = canvas.width = window.innerWidth;
    H = canvas.height = window.innerHeight;
    nodes = [];
    segments = [];
    pulses = [];

    const cols = Math.ceil(W / GRID) + 2;
    const rows = Math.ceil(H / GRID) + 2;
    const map: Record<string, number> = {};

    for (let r = 0; r < rows; r++) {
      for (let c = 0; c < cols; c++) {
        const active = Math.random() < 0.28;
        const key = `${c},${r}`;
        map[key] = nodes.length;
        nodes.push({
          x: c * GRID + GRID / 2 + (Math.random() - 0.5) * 8,
          y: r * GRID + GRID / 2 + (Math.random() - 0.5) * 8,
          active,
          hex: active && Math.random() < 0.12,
        });
      }
    }

    for (let r = 0; r < rows; r++) {
      for (let c = 0; c < cols; c++) {
        const idx = map[`${c},${r}`];
        if (!nodes[idx]?.active) continue;
        const rIdx = map[`${c + 1},${r}`];
        const bIdx = map[`${c},${r + 1}`];
        if (rIdx !== undefined && nodes[rIdx]?.active && Math.random() < 0.38) {
          segments.push({ from: idx, to: rIdx });
        }
        if (bIdx !== undefined && nodes[bIdx]?.active && Math.random() < 0.38) {
          segments.push({ from: idx, to: bIdx });
        }
      }
    }
  }

  function hexPath(cx: number, cy: number, r: number) {
    ctx.beginPath();
    for (let i = 0; i < 6; i++) {
      const a = (i * Math.PI) / 3 - Math.PI / 6;
      const x = cx + r * Math.cos(a);
      const y = cy + r * Math.sin(a);
      i === 0 ? ctx.moveTo(x, y) : ctx.lineTo(x, y);
    }
    ctx.closePath();
  }

  let lastSpawn = 0;

  function draw(ts: number) {
    ctx.clearRect(0, 0, W, H);

    // Draw segments (circuit traces)
    ctx.lineWidth = 1;
    for (const seg of segments) {
      const a = nodes[seg.from];
      const b = nodes[seg.to];
      ctx.beginPath();
      // L-shaped routing like real PCB traces
      ctx.moveTo(a.x, a.y);
      ctx.lineTo(a.x, b.y);
      ctx.lineTo(b.x, b.y);
      ctx.strokeStyle = 'rgba(0, 160, 200, 0.055)';
      ctx.stroke();
    }

    // Draw nodes
    for (const node of nodes) {
      if (!node.active) continue;
      if (node.hex) {
        hexPath(node.x, node.y, 5);
        ctx.strokeStyle = 'rgba(0, 229, 255, 0.09)';
        ctx.lineWidth = 1;
        ctx.stroke();
      } else if (Math.random() < 0.003) {
        // occasional shimmer
        ctx.beginPath();
        ctx.arc(node.x, node.y, 2, 0, Math.PI * 2);
        ctx.fillStyle = 'rgba(0, 229, 255, 0.18)';
        ctx.fill();
      } else {
        ctx.beginPath();
        ctx.arc(node.x, node.y, 1.5, 0, Math.PI * 2);
        ctx.fillStyle = 'rgba(0, 180, 220, 0.07)';
        ctx.fill();
      }
    }

    // Spawn pulses
    if (ts - lastSpawn > 250 && pulses.length < 18) {
      lastSpawn = ts;
      const si = Math.floor(Math.random() * segments.length);
      const cyan = Math.random() < 0.65;
      pulses.push({
        seg: si,
        t: 0,
        speed: 0.0035 + Math.random() * 0.005,
        colorStr: cyan ? '0,229,255' : '21,101,255',
      });
    }

    // Draw pulses
    for (let i = pulses.length - 1; i >= 0; i--) {
      const p = pulses[i];
      p.t += p.speed;
      if (p.t > 1) { pulses.splice(i, 1); continue; }

      const seg = segments[p.seg];
      if (!seg) { pulses.splice(i, 1); continue; }
      const a = nodes[seg.from];
      const b = nodes[seg.to];

      // Follow the L-shaped path
      let x: number, y: number;
      // First leg: a.x, a.y → a.x, b.y  (vertical)
      // Second leg: a.x, b.y → b.x, b.y (horizontal)
      const leg1 = Math.abs(b.y - a.y);
      const leg2 = Math.abs(b.x - a.x);
      const total = leg1 + leg2;
      const traveled = p.t * total;

      if (traveled <= leg1) {
        x = a.x;
        y = a.y + (b.y - a.y) * (leg1 > 0 ? traveled / leg1 : 0);
      } else {
        x = a.x + (b.x - a.x) * (leg2 > 0 ? (traveled - leg1) / leg2 : 0);
        y = b.y;
      }

      const g = ctx.createRadialGradient(x, y, 0, x, y, 14);
      g.addColorStop(0, `rgba(${p.colorStr},0.75)`);
      g.addColorStop(0.35, `rgba(${p.colorStr},0.2)`);
      g.addColorStop(1, `rgba(${p.colorStr},0)`);
      ctx.beginPath();
      ctx.arc(x, y, 14, 0, Math.PI * 2);
      ctx.fillStyle = g;
      ctx.fill();

      ctx.beginPath();
      ctx.arc(x, y, 2, 0, Math.PI * 2);
      ctx.fillStyle = `rgba(${p.colorStr},1)`;
      ctx.fill();
    }

    requestAnimationFrame(draw);
  }

  build();
  window.addEventListener('resize', build, { passive: true });
  requestAnimationFrame(draw);
})();
</script>

<style>
  #circuit-bg {
    position: fixed;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
    pointer-events: none;
  }
</style>
